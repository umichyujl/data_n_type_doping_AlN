##General
system MgAlN_96atoms

## Output writing ##
LWAVE = .T.    # Writes WAVECAR, .F. or no line to not write WAVECAR
LCHARG = .T.   # Writes CHGCAR, .F. or no line to not write CHGCAR
#LORBIT = 11    # Writes DOSCAR and PROCAR, so DOS data in both total and split by element and orbital character
#NEDOS = 5000   # This says how many data points for your energy range in your DOS. Default is much smaller and too small.
LVTOT = .T.

## electronic settings ##
ISMEAR = 0     # Gaussian smearing method
#SIGMA = 0.02   # Amount of smearing, this is very small and my standard
ENCUT = 500    # Energy cutoff, should be converged, ENMAX in POTCARS gives good estimate to start with
EDIFF = 1E-05  # Electronic relaxation convergence criterion. 1E-5 is standard, 1E-6 is good, high accuracy for HSE, 1E-8 is a high accuracy you should use if going into GW 
#NELM = 300     # Max number of electronic steps, default is 60, usually want a higher number to ensure convergence
#NELMIN = 8     # Min number of electronic steps, want for stability primarily in structure relaxations
#LASPH = .TRUE.
#ADDGRID = .TRUE.
#LOPTICS = .TRUE.
#PREC = Accurate  # Defaults to Normal, usually good but use Accurate if going to GW
#ALGO = Normal    # Electronic optimization algorithm; options for scf and relaxation are Very Fast, Fast, and Normal. speeds match name, Normal is the most stable if getting errors.
################## Different ALGOs will be used for HSE, GW, BSE, other things.
NELECT = 290   # 289.0000    total number of electrons

## Ionic / structure settings ##
ISIF = 2       # Structure relax command; 3 relaxes ions and cell volume / shape change; 2 is relax ions with force and stress, no unit cell change; other options in manual
IBRION = -1    # Ionic relaxation algorithm; 2=conjugate gradient method, 1=good for preconverged, -1=for sfc before DOS, band
NSW = 0      # Maximum number of ionic steps, much higher than default - usually want this way to be sure of convergence 
#POTIM = 0.05    # This scales the ionic steps to be bigger or smaller, sometimes needs used to help convergence
EDIFFG = -2E-2 # The the ionic convergence criterion. negative values are a max force on atoms, positive is a max total energy change. -1E-3 is often good, sometimes slow/overkill

## HSE06 ##
LHFCALC = .T. ; HFSCREEN = 0.2             # These turn on HSE calculations and match the settings for HSE06
#ALGO = D ; TIME = 0.2 ; PRECFOCK = Normal  # HSE uses different ALGOs than normal. Be sure to comment out the ALGO from up above if doing HSE!!
ALGO = All ; PRECFOCK = Fast               # Any one of these three lines can be used, try them all out if getting errors or no convergence only in HSE
#ALGO = Damped; TIME = 0.4 ; PRECFOCK = Fast;
AEXX = 0.33

## Parallelization ##
#NBANDS = 672     # Number of electronic bands. For non spin-polarizations, must be greater than half the number of electrons (look at pseudopotentials used)
################ Make this a multiple of the number of cpus being used for efficiency.
KPAR = 8        # Kpoint parallelization - optional, make divisible into cores, smallest of number of nodes or kpoints
NPAR = 32       # Band parallelization - optional, make equal to number of nodes
LREAL = Auto   # Realspace / reciprocal projection scheme (I think) - use Auto for most systems, use .F. for small (few atoms) - VASP will print warning if needed

